# Copie este arquivo para .env e preencha os valores

# Chave Fernet para encriptar credenciais no cofre
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_KEY=

# Chave de API para proteger o endpoint /consultar
# Deixe vazio para desabilitar autenticacao (somente dev)
API_KEY=

# Cache de resultados por CNPJ (segundos). 0 = desativado
CACHE_TTL_SECONDS=28800

# Rate limit do endpoint /consultar (ex: "10/minute", "100/hour")
RATE_LIMIT=10/minute

# Timeout de espera sincrona no /consultar (segundos)
CONSULTAR_TIMEOUT_SECONDS=180

# Maximo de browsers simultaneos
MAX_CONCURRENCY=2

# Rodar o browser com interface visual (true em prod, false para depurar)
HEADLESS=true

# Origens permitidas no CORS
CORS_ORIGINS=http://localhost:5200,http://127.0.0.1:5200
