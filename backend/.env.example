# URL do portal alvo
PORTAL_URL=https://portal.multiplike.com.br/

# Navegador headless (true em produção; false no dev para mapear seletores)
HEADLESS=true

# Timeout de navegação em ms
NAV_TIMEOUT=45000

# Origens permitidas no CORS
CORS_ORIGINS=http://localhost:5200,http://127.0.0.1:5200

# Concorrência e retries
MAX_CONCURRENCY=2
MAX_RETRIES=2

# TTLs (segundos)
JOB_TTL_SECONDS=21600       # jobs/arquivos removidos após 6h
SESSION_TTL_SECONDS=1200    # sessão reutilizável por 20min
CLEANUP_INTERVAL_SECONDS=600

LOG_LEVEL=INFO

# Chave-mestra do cofre de credenciais (Fernet). Gere uma vez com:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# Guarde em local seguro. Se mudar, as credenciais salvas ficam ilegíveis.
CREDENTIALS_KEY=

# OBS: as credenciais do portal NÃO ficam aqui. São cadastradas uma vez na UI
# (aba "Credenciais do portal"), testadas e guardadas CIFRADAS no cofre do backend.
